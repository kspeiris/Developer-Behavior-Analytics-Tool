{
  "name": "dbat",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "main.cjs",
  "description": "Developer Behavior Analytics Tool (DBAT)",
  "author": "Kavindu Peiris",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"npm:dev:vite\" \"npm:dev:electron:watch\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "build:electron": "npx tsc -p tsconfig.node.json",
    "dev:electron:watch": "npx tsc -p tsconfig.node.json --watch",
    "dev:electron": "wait-on tcp:5173 dist-electron/preload.cjs dist-electron/db/index.js && set VITE_DEV_SERVER_URL=http://localhost:5173 && electron .",
    "build": "vite build && npx tsc -p tsconfig.node.json",
    "start": "npm run build && electron .",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run rebuild && npm run build && electron-builder"
  },
  "dependencies": {
    "@octokit/request": "^9.2.0",
    "better-sqlite3": "^11.1.2",
    "clsx": "^2.1.1",
    "keytar": "^7.9.0",
    "lucide-react": "^0.563.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.kavindu.dbat",
    "productName": "DBAT",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.cjs",
      "assets/icon.ico",
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DBAT"
    }
  }
}
